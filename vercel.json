{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/mazebank-frontend" }
    }
  ],
  "routes": [
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },
    { "src": "^/favicon.ico$", "dest": "/favicon.ico" },
    { "src": "^(?:.*)$", "dest": "/index.html" }
  ],
  "cleanUrls": true
}
